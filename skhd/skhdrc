# --- Window Focus Shortcuts ---
# Control + H: Focus window to the left
ctrl - h : yabai -m window --focus west

# Control + L: Focus window to the right
ctrl - l : yabai -m window --focus east

# Control + J: Focus window above
ctrl - j : yabai -m window --focus north

# Control + K: Focus window below
ctrl - k : yabai -m window --focus south

# Toggle floating state for any focused window
ctrl - return : yabai -m window --toggle float

# Resize windows (hold ctrl + alt)
ctrl + alt - h : yabai -m window --resize left:-50:0
ctrl + alt - l : yabai -m window --resize right:50:0
ctrl + alt - j : yabai -m window --resize top:0:50
ctrl + alt - k : yabai -m window --resize bottom:0:-50

# Swap windows
shift + ctrl - h : yabai -m window --swap west
shift + ctrl - l : yabai -m window --swap east
shift + ctrl - j : yabai -m window --swap north
shift + ctrl - k : yabai -m window --swap south

# Warp Windows
ctrl + alt + shift - h : yabai -m window --warp west
ctrl + alt + shift - l : yabai -m window --warp east
ctrl + alt + shift - j : yabai -m window --warp north
ctrl + alt + shift - k : yabai -m window --warp south

# Layout Reset. 
ctrl + alt - r : yabai -m space --balance